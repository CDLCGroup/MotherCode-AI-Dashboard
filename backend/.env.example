# Lucky Lefty Environment Configuration
# Copy this to .env and fill in your values

# Server
NODE_ENV=development
PORT=3001          # Phase 2: 3001 matches the frontend's VITE_API_URL/VITE_WS_URL defaults
HOST=localhost

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=lefty_user
DB_PASSWORD=lefty_password
DB_NAME=lucky_lefty

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRY=7d

# Voice & AI
WHISPER_MODEL=base  # tiny, base, small, medium, large
# OpenAI doubles as the BACKUP speech provider: STT falls back Deepgram→Whisper and
# TTS falls back ElevenLabs→OpenAI when the primary is unconfigured or errors.
OPENAI_API_KEY=sk-...  # Backup STT (Whisper) + TTS provider; also Whisper cloud
OPENAI_STT_MODEL=whisper-1   # optional override for the STT fallback
OPENAI_TTS_MODEL=tts-1       # optional override for the TTS fallback
OPENAI_TTS_VOICE=alloy       # optional OpenAI TTS voice
# Intent router: when set, claude-opus-4-8 classifies each voice command into
# intent + agent domains (structured tool output). Keyless fallback = regex
# router, so this is optional. ANTHROPIC_API_KEY and CLAUDE_API_KEY are both
# accepted (ANTHROPIC_API_KEY wins). Override the model with MOTHERCODE_ROUTER_MODEL.
CLAUDE_API_KEY=sk-ant-...  # For intent parsing + conversational replies (claude-opus-4-8)
# ANTHROPIC_API_KEY=sk-ant-...
# MOTHERCODE_ROUTER_MODEL=claude-opus-4-8

# Speech-to-text (Phase 2 voice loop)
DEEPGRAM_API_KEY=...  # Deepgram streaming STT

# Text-to-speech (Phase 2 voice loop) — optional; browser speechSynthesis is the default
ELEVENLABS_API_KEY=sk_...        # For TTS (server-side /api/voice/tts)
ELEVENLABS_VOICE_ID=...          # Picked voice (e.g. dOqxOZEisn8SiUH1dPCC)
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# Optional — only for the HOSTED ElevenLabs conversational-agent webhook path (2b):
# VOICE_WEBHOOK_PATH=/api/voice-webhook
# ELEVENLABS_WEBHOOK_SECRET=...  # HMAC signing secret to verify inbound webhooks

# Integrations
# Google Calendar & Gmail OAuth
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
# MUST be byte-identical to the Authorized redirect URI in Google Cloud Console.
# Backend serves the callback on PORT 3001 — see SETUP-google.md.
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Paystack (FinanceAgent) — payments/revenue for the finance domain. Keyless:
# without the secret key the agent says "connect Paystack" and never fabricates
# numbers. Secret key starts with sk_test_ / sk_live_.
PAYSTACK_SECRET_KEY=sk_test_...
# PAYSTACK_PUBLIC_KEY=pk_test_...   # reserved for any future client-side init

# Slack (outbound subagent-chat notifications — see SETUP-slack.md)
SLACK_BOT_TOKEN=xoxb-...        # Bot token (starts with xoxb-); scope: chat:write
SLACK_CHANNEL=#mothercode-notifications   # Channel the voice loop threads under
SLACK_SIGNING_SECRET=...        # Reserved for the future inbound (Events API) phase

# Buffer (social scheduling — SocialAgent)
BUFFER_API_KEY=...
BUFFER_CHANNEL_TIKTOK=...
BUFFER_CHANNEL_INSTAGRAM=...

# TikTok archive (TikTokAgent → existing tt_scraper pipeline). Voice-triggerable
# via "archive N tiktok videos about X". Keyless: if the runner/dir are absent on
# this host the agent speaks a "pipeline not found" message. Defaults point at the
# deployed Windows pipeline; override per host.
TT_SCRAPER_RUNNER=C:\Users\o3sha\tt_scraper_runner.ps1
TT_SCRAPER_DIR=F:\tiktok_archiver
TT_SCRAPER_DRIVE=0              # 1 = also upload to Drive (needs one-time OAuth); 0 = -SkipDriveUpload

# File agent (FileManagerAgent) — sandbox dir for voice-created notes. All file
# ops are confined here (no traversal, no deletes, .md/.txt only). Default:
# <repo>/outputs/notes. Set an absolute path to point it at e.g. an Obsidian vault.
# MOTHERCODE_FILES_DIR=C:\Users\o3sha\Downloads\Obsidian Vault\Mother Code\outputs\notes

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Feature Flags
ENABLE_GOOGLE_CALENDAR=true
ENABLE_GMAIL=true
ENABLE_STRIPE=true
ENABLE_SOCIAL_MEDIA=true
ENABLE_ANALYTICS=true

# Development
DEBUG=false
MOCK_APIS=false
