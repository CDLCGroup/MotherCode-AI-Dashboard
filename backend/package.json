{
  "name": "lucky-lefty-backend",
  "version": "0.1.0",
  "description": "Lucky Lefty - Voice-first AI agent backend",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "migrate": "node db/migrate.js",
    "seed": "node db/seed.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --fix"
  },
  "keywords": [
    "voice",
    "ai",
    "agent",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "morgan": "^1.10.0",
    "pg": "^8.10.0",
    "ws": "^8.21.0"
  },
  "_phase2Dependencies": {
    "_comment": "Pruned from Phase 1 to keep `npm install` clean (native builds removed). Re-add as the features land: voice capture, queues, auth, external APIs.",
    "axios": "^1.4.0 (external API calls)",
    "bull": "^4.10.4 (job queue, needs redis)",
    "node-microphone": "^0.1.3 (NATIVE — voice capture)",
    "wav": "^1.0.2 (audio encoding)",
    "fluent-ffmpeg": "^2.1.2 (needs ffmpeg binary)",
    "openai": "^4 (Whisper/LLM — note: v3 in original was outdated)",
    "jsonwebtoken": "^9.0.0 (auth)",
    "bcrypt": "^5.1.0 (NATIVE — password hashing; consider bcryptjs)",
    "uuid": "^9.0.0",
    "winston": "^3.8.2 (logging)",
    "keytar": "^7.9.0 (NATIVE — OS keychain for secrets)"
  },
  "devDependencies": {
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
