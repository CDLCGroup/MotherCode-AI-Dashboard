# Obsidian vault config/cache (not application code)
.obsidian/

# Secrets — GCP service-account keys & credential files (any depth).
# The real key is JarvisGCPServiceAccount.json; the generic ignores below
# don't match it by name, so the wildcard is the actual guard.
*ServiceAccount*.json
*serviceaccount*.json
service_account.json
credentials.json

# Google OAuth user tokens (Calendar + Gmail agents) — written at /auth/google
.google-tokens.json

# MCP config holds the live Obsidian Local REST API key — keep .mcp.json.example as the tracked template
.mcp.json
